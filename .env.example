SECRET_KEY=change-me-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

OLLAMA_UPSTREAM_BASE_URL=http://127.0.0.1:11434
ENABLE_STREAMING=True
DEFAULT_RATE_LIMIT=60/min
LOG_RETENTION_DAYS=30

# Redis (leave empty to use in-memory cache for local dev)
REDIS_URL=

# Database path (optional, defaults to ./db.sqlite3)
# DATABASE_PATH=/app/db/db.sqlite3

# Admin account (created on first run via: docker compose exec web python manage.py createsuperuser)
# ADMIN_USER=admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me
